{
  "env": {
    "node": true,
    "es2021": true,
    "jest": true
  },
  "ignorePatterns": ["src/migrations/**/*.js"],
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 12
  },
  "rules": {
    "no-unused-vars": ["error", { "argsIgnorePattern": "^_|^next" }],
    "no-console": "off",
    "no-var": "error",
    "prefer-const": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "multi-line"],
    "no-undef": "error"
  }
}
