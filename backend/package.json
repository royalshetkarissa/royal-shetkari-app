{
  "name": "royal-shetkari-backend",
  "version": "1.0.0",
  "description": "Node.js + Express API for the Royal Shetkari farmer app.",
  "main": "src/server.js",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/server.js",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "eslint \"src/**/*.js\" --fix",
    "format": "prettier --write \"src/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.js\"",
    "test": "jest --runInBand --passWithNoTests"
  },
  "keywords": [
    "royal-shetkari",
    "express",
    "postgresql",
    "jwt"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1053.0",
    "@aws-sdk/s3-request-presigner": "^3.1053.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.76.6",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.1",
    "express-rate-limit": "^8.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.20.0",
    "rate-limit-redis": "^5.0.0",
    "twilio": "^6.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.2.5",
    "supertest": "^6.3.4"
  },
  "overrides": {
    "qs": "^6.15.2",
    "ip-address": "^10.1.1",
    "brace-expansion": "^5.0.6"
  },
  "type": "commonjs"
}
